# ---- Shri Sai Ayurveda — environment ----
# Copy this file to .env.local and fill in real values.

# PostgreSQL connection string used by the admin panel & booking storage.
# Local example:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sai_ayurveda
# Hosted (Supabase/Neon/RDS) example (SSL auto-enabled for non-localhost):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# Secret used to sign admin login sessions (JWT). Use a long random string.
AUTH_SECRET=change-me-to-a-long-random-string

# ---- EmailJS (client-side booking notifications to the clinic) ----
# These are PUBLIC by design (EmailJS is a client-side service).
# Create them at https://www.emailjs.com → Email Services + Email Templates.
# If left blank, bookings still work — no email is sent.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
# The inbox that should receive booking alerts (defaults to shivsai81@gmail.com).
NEXT_PUBLIC_CLINIC_EMAIL=shivsai81@gmail.com

# ---- Google Meet (auto-create a Meet link per appointment) ----
# One-time OAuth setup (see README "Google Meet setup"). If left blank, the
# email uses a "start a meeting" fallback link instead of a scheduled one.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
