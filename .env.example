# ---- Shri Sai Ayurveda — environment ----
# Copy this file to .env.local and fill in real values.

# PostgreSQL connection string used by the admin panel & booking storage.
# Local example:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sai_ayurveda
# Hosted (Supabase/Neon/RDS) example (SSL auto-enabled for non-localhost):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# Secret used to sign admin login sessions (JWT). Use a long random string.
AUTH_SECRET=change-me-to-a-long-random-string
